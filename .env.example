# oci-free-cloud-lab-starter — environment configuration template
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# SETUP ORDER:
#   1. Fill in all OCI_* values (from OCI console / oci setup config)
#   2. Set FLEET_REPO to your fork of this repo (SSH URL)
#   3. Set GITHUB_TOKEN (read-only PAT with repo scope)
#   4. Generate ADMIN_PASSWORD_HASH:
#        python admin/hash_password.py
#   5. Set NOTIFY_NTFY_TOPIC if you want push notifications
#   6. After VMs are launched, fill in the OCI_*_HOST values

# ── OCI Credentials ────────────────────────────────────────────────────────────
OCI_TENANCY_OCID=ocid1.tenancy.oc1..
OCI_USER_OCID=ocid1.user.oc1..
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_KEY_FILE=~/.oci/oci_api_key.pem
OCI_REGION=us-ashburn-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..
OCI_AVAILABILITY_DOMAIN=AD-1

# ── Network (created by setup-oci-network) ─────────────────────────────────────
OCI_VCN_ID=ocid1.vcn.oc1..
OCI_SUBNET_ID=ocid1.subnet.oc1..

# ── SSH Key (for VM access) ────────────────────────────────────────────────────
# Path to your local SSH private key for connecting to fleet VMs.
# Public key goes in the launch profiles (admin/profiles/*.json).
OCI_SSH_PRIVATE_KEY_PATH=~/.ssh/fleet.key
OCI_SSH_USER=ubuntu

# ── Fleet SSH Key — Persistence Across Relaunches ──────────────────────────────
# By default each VM generates a fresh fleet.key on first boot. When management
# relaunches, worker and lab still trust the OLD key and SSH breaks. Fix options:
#
# Option 1 — OCI Vault (recommended): store the fleet private key as a Vault secret.
# Prereqs (run once):
#   a. Create a Vault + Master Encryption Key in the OCI console.
#   b. Store the fleet private key:
#        oci vault secret create-base64 --vault-id <vault-ocid> \
#            --key-id <mek-ocid> --compartment-id <compartment-ocid> \
#            --secret-name fleet-private-key \
#            --secret-content-content "$(base64 -w 0 < ~/.ssh/fleet.key)"
#   c. Create a dynamic group: ALL {instance.compartment.id = '<compartment-ocid>'}
#   d. Add a policy: Allow dynamic-group <name> to read secret-family in compartment id <ocid>
#   e. Paste the secret OCID below.
FLEET_OCI_VAULT_SECRET_OCID=

# Option 2 — Base64 env var (fallback). WARNING: embeds private key in launch metadata.
# Generate: base64 -w 0 < ~/.ssh/fleet.key
FLEET_PRIVATE_KEY_B64=

# Option 3 — Admin recovery key (strongly recommended). Adds your personal public key
# to every VM's authorized_keys at boot so you can SSH in even if the fleet key rotates.
# Paste the full one-line public key (e.g. output of: cat ~/.ssh/id_ed25519.pub)
ADMIN_SSH_PUBLIC_KEY=

# ── Fleet Identity ─────────────────────────────────────────────────────────────
# Human-readable name shown in the admin console and ntfy notifications.
FLEET_NAME=My Cloud Lab

# GitHub SSH URL for this repo — VMs clone it on first boot.
FLEET_REPO=git@github.com:your-username/oci-free-cloud-lab-starter.git

# GitHub personal access token (read-only, repo scope).
# Used by VMs to pull the repo. Never needs write access.
GITHUB_TOKEN=github_pat_...

# ── MDA Laboratory Workload ───────────────────────────────────────────────────
# The laboratory VM clones and runs this dashboard repo immediately after boot.
DASHBOARD_REPO=MountDiabloAdvisors/dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8700
DASHBOARD_DB_PATH=/home/ubuntu/mda-dashboard-data/dashboard.db

# Optional dashboard secrets. Leave blank to boot with SQLite + unauthenticated local dashboard.
DASHBOARD_DATABASE_URL=
DASHBOARD_SCHWAB_APP_KEY=
DASHBOARD_SCHWAB_APP_SECRET=
DASHBOARD_SCHWAB_MARKET_APP_KEY=
DASHBOARD_SCHWAB_MARKET_APP_SECRET=
DASHBOARD_PLAID_CLIENT_ID=
DASHBOARD_PLAID_SECRET=
DASHBOARD_PLAID_ENV=sandbox
DASHBOARD_COINGECKO_API_KEY=

# ── Admin Console ──────────────────────────────────────────────────────────────
# Plaintext password — used only to generate the hash below. Never sent to a VM.
ADMIN_PASSWORD=

# PBKDF2 hash of your admin password.
# Generate with:  python admin/hash_password.py
ADMIN_PASSWORD_HASH=

# Username for the admin console (default: admin)
ADMIN_USERNAME=admin

# Your DuckDNS subdomain — Caddy uses this for TLS.
ADMIN_DOMAIN=my-lab.duckdns.org

# ── Push Notifications (ntfy) — optional ──────────────────────────────────────
# Set a unique, hard-to-guess topic name to receive fleet alerts via ntfy.sh.
# Leave blank to disable ntfy entirely.
NOTIFY_NTFY_TOPIC=

# Override if you self-host ntfy. Defaults to https://ntfy.sh
# NOTIFY_NTFY_SERVER=https://ntfy.sh

# ── External Watchdog (UptimeRobot) — optional ────────────────────────────────
# UptimeRobot (uptimerobot.com) is free for up to 50 monitors (5-min intervals).
# It provides an external "who watches the watcher" layer that fires even when
# ALL three fleet VMs are simultaneously unreachable.
#
# Setup:
#   1. Sign up at https://uptimerobot.com (free, no credit card)
#   2. Create an HTTPS monitor targeting: https://<ADMIN_DOMAIN>/health
#   3. In Alert Contacts, add a Webhook pointing to:
#        https://ntfy.sh/<NOTIFY_NTFY_TOPIC>
#      (UptimeRobot will POST to ntfy directly when the admin console is down)
#
# The API key below is optional — reserved for future admin console integration.
UPTIMEROBOT_API_KEY=

# ── DuckDNS (for admin console HTTPS) ─────────────────────────────────────────
# Your DuckDNS token — Caddy uses this for the ACME DNS challenge.
DUCKDNS_TOKEN=

# ── VM Hostnames (filled in after VMs are launched) ───────────────────────────
# Public IPs or hostnames for SSH and local admin scripts.
OCI_MANAGEMENT_HOST=
OCI_WORKER_HOST=
OCI_LABORATORY_HOST=

# ── Internal Network (filled in after VMs are launched) ───────────────────────
# Private IPs for VM-to-VM communication (free, stays within OCI VCN).
FLEET_MANAGEMENT_PRIVATE_IP=
FLEET_WORKER_PRIVATE_IP=
FLEET_LABORATORY_PRIVATE_IP=

# ── Fleet Security ─────────────────────────────────────────────────────────────
# Shared secret for heartbeat endpoint authentication (optional but recommended).
# When set, worker/laboratory include "Authorization: Bearer <token>" in heartbeats.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLEET_HEARTBEAT_TOKEN=

# API key for the /enqueue endpoint — lets an LLM agent queue jobs via Bearer token.
QUEUE_API_KEY=
