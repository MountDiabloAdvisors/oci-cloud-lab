# oci-free-cloud-lab-starter — environment configuration template
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# SETUP ORDER:
#   1. Fill in all OCI_* values (from OCI console / oci setup config)
#   2. Set FLEET_REPO to your fork of this repo (SSH URL)
#   3. Set GITHUB_TOKEN (read-only PAT with repo scope)
#   4. Generate ADMIN_PASSWORD_HASH:
#        python admin/hash_password.py
#   5. Set NOTIFY_NTFY_TOPIC if you want push notifications
#   6. After VMs are launched, fill in the OCI_*_HOST values

# ── OCI Credentials ────────────────────────────────────────────────────────────
OCI_TENANCY_OCID=ocid1.tenancy.oc1..
OCI_USER_OCID=ocid1.user.oc1..
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_KEY_FILE=~/.oci/oci_api_key.pem
OCI_REGION=us-ashburn-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..
OCI_AVAILABILITY_DOMAIN=AD-1

# ── Network (created by setup-oci-network) ─────────────────────────────────────
OCI_VCN_ID=ocid1.vcn.oc1..
OCI_SUBNET_ID=ocid1.subnet.oc1..

# ── SSH Key (for VM access) ────────────────────────────────────────────────────
# Path to the private key for SSHing into fleet VMs.
# Public key fingerprint goes in the launch profiles.
FLEET_SSH_KEY=~/.ssh/fleet.key

# ── Fleet Identity ─────────────────────────────────────────────────────────────
# Human-readable name shown in the admin console and ntfy notifications.
FLEET_NAME=My Cloud Lab

# GitHub SSH URL for this repo — VMs clone it on first boot.
FLEET_REPO=git@github.com:your-username/oci-free-cloud-lab-starter.git

# GitHub personal access token (read-only, repo scope).
# Used by VMs to pull the repo. Never needs write access.
GITHUB_TOKEN=github_pat_...

# ── Admin Console ──────────────────────────────────────────────────────────────
# PBKDF2 hash of your admin password.
# Generate with:  python admin/hash_password.py
ADMIN_PASSWORD_HASH=pbkdf2:sha256:...

# ── Push Notifications (ntfy.sh) ──────────────────────────────────────────────
# Optional. Set a unique, hard-to-guess topic name to receive alerts.
# Leave blank to disable ntfy entirely.
NOTIFY_NTFY_TOPIC=

# ── DuckDNS (for admin console HTTPS) ─────────────────────────────────────────
# Optional. Needed if you want Caddy to get a real TLS cert via DuckDNS.
DUCKDNS_DOMAIN=my-lab.duckdns.org
DUCKDNS_TOKEN=

# ── VM Hostnames (filled in after VMs are launched) ───────────────────────────
# Public IPs or hostnames for SSH and laptop-side tools.
OCI_MANAGEMENT_HOST=
OCI_WORKER_HOST=
OCI_LAB_VM_HOST=

# ── Internal Network (filled in after VMs are launched) ───────────────────────
# Private IPs for VM-to-VM communication (free, stays within OCI VCN).
FLEET_MANAGEMENT_PRIVATE_IP=
FLEET_WORKER_PRIVATE_IP=
FLEET_LAB_VM_PRIVATE_IP=
